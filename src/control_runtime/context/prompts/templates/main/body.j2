  },
  "investigation_targets": ["ue_binding", "qos_flow_binding", "policy_feasibility"],
  "uncertainty_flags": ["identifier_risk", "runtime_evidence_missing"],
  "retry_scope": "full_reground",
  "required_evidence": ["<evidence IEA/OSA must obtain>"],
